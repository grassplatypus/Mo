<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Mo.Views.DisplayTuningPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Padding="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Monitor list -->
        <StackPanel Spacing="8">
            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="SubtitleText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
            <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" Margin="0,8,0,0" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <TextBlock x:Name="RefreshLabel" />
                </StackPanel>
            </Button>
            <ListView x:Name="MonitorList" SelectionChanged="MonitorList_SelectionChanged" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Detail panel -->
        <ScrollViewer Grid.Column="1" Padding="24,0,0,0">
            <StackPanel x:Name="DetailPanel" Spacing="12" Visibility="Collapsed">

                <!-- Header -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="HeaderName" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="HeaderBrand" Opacity="0.7" Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock x:Name="HeaderDetails" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <!-- DDC/CI basic -->
                <Grid x:Name="DdcCard" Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DdcTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Button Grid.Column="1" x:Name="ResetBtn" Click="ResetBtn_Click" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="BrightnessLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="100" ValueChanged="Slider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="BrightnessValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ContrastLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="ContrastSlider" Minimum="0" Maximum="100" ValueChanged="Slider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="ContrastValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="R" Foreground="#FF4444" FontWeight="Bold" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="RedSlider" Minimum="0" Maximum="100" ValueChanged="Slider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="RedValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="G" Foreground="#44BB44" FontWeight="Bold" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="GreenSlider" Minimum="0" Maximum="100" ValueChanged="Slider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="GreenValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="B" Foreground="#4488FF" FontWeight="Bold" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="BlueSlider" Minimum="0" Maximum="100" ValueChanged="Slider_ValueChanged" />
                            <TextBlock Grid.Column="2" x:Name="BlueValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock x:Name="DdcEmptyText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" Visibility="Collapsed" />
                    </StackPanel>
                </Grid>

                <!-- Color preset (VCP 0x14) -->
                <Grid x:Name="PresetCard" Padding="16" CornerRadius="8" Visibility="Collapsed"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="PresetLabel" />
                        <TextBlock x:Name="PresetDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="PresetCombo" MinWidth="160" SelectionChanged="PresetCombo_SelectionChanged" VerticalAlignment="Center" />
                </Grid>

                <!-- HDR -->
                <Grid x:Name="HdrCard" Padding="16" CornerRadius="8" Visibility="Collapsed"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="HdrLabel" />
                        <TextBlock x:Name="HdrDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" x:Name="HdrToggle" Toggled="HdrToggle_Toggled" OnContent="" OffContent="" />
                </Grid>

                <!-- AMD (ADL2) color controls -->
                <Grid x:Name="AmdCard" Padding="16" CornerRadius="8" Visibility="Collapsed"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="AmdTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="AmdSaturationLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="AmdSaturationSlider" ValueChanged="AmdSlider_ValueChanged" Tag="Saturation" />
                            <TextBlock Grid.Column="2" x:Name="AmdSaturationValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="AmdHueLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="AmdHueSlider" ValueChanged="AmdSlider_ValueChanged" Tag="Hue" />
                            <TextBlock Grid.Column="2" x:Name="AmdHueValue" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
