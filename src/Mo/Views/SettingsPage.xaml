<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Mo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:Mo.Helpers"
    xmlns:models="using:Mo.Models"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="4" MaxWidth="760" HorizontalAlignment="Stretch">

            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

            <!-- General -->
            <tk:SettingsExpander x:Uid="GeneralExpander" IsExpanded="True">
                <tk:SettingsExpander.Items>
                    <tk:SettingsCard x:Uid="LaunchAtStartupCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                    <tk:SettingsCard x:Uid="MinimizeToTrayCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.MinimizeToTrayOnClose, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                    <tk:SettingsCard x:Uid="StartMinimizedCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

            <!-- Appearance -->
            <tk:SettingsCard x:Uid="ThemeCard">
                <ComboBox MinWidth="160"
                          ItemsSource="{x:Bind ThemeOptions, Mode=OneTime}"
                          SelectedItem="{x:Bind ViewModel.Theme, Mode=TwoWay}" />
            </tk:SettingsCard>

            <!-- Profiles -->
            <tk:SettingsExpander x:Uid="ProfilesExpander" IsExpanded="True">
                <tk:SettingsExpander.Items>
                    <tk:SettingsCard x:Uid="AutoSwitchCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AutoSwitchEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                    <tk:SettingsCard x:Uid="HotkeysCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.HotkeysEnabled, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                    <tk:SettingsCard x:Uid="RestoreOnStartupCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.RestoreOnStartup, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                    <tk:SettingsCard x:Uid="RestoreColorCard">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.RestoreColorOnStartup, Mode=TwoWay}" OnContent="" OffContent="" />
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

            <!-- Updates -->
            <tk:SettingsCard x:Uid="UpdateCheckCard">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="UpdateStatusText"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               Visibility="Collapsed" />
                    <ToggleSwitch IsOn="{x:Bind ViewModel.CheckForUpdates, Mode=TwoWay}" OnContent="" OffContent="" />
                    <Button x:Name="CheckNowButton" Click="CheckNowButton_Click" VerticalAlignment="Center">
                        <TextBlock x:Uid="CheckNowText" />
                    </Button>
                </StackPanel>
            </tk:SettingsCard>

            <!-- Advanced -->
            <tk:SettingsExpander x:Uid="AdvancedExpander">
                <tk:SettingsExpander.Items>
                    <tk:SettingsCard x:Uid="RotationMethodCard">
                        <ComboBox x:Name="RotationMethodCombo"
                                  MinWidth="200"
                                  ItemsSource="{x:Bind RotationOptions, Mode=OneTime}"
                                  SelectedValue="{x:Bind ViewModel.RotationMethod, Mode=TwoWay}"
                                  SelectedValuePath="Method"
                                  DisplayMemberPath="DisplayName" />
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

            <!-- About / system info -->
            <tk:SettingsExpander x:Uid="AboutExpander">
                <tk:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </tk:SettingsExpander.HeaderIcon>
                <tk:SettingsExpander.Items>
                    <tk:SettingsCard ContentAlignment="Vertical">
                        <StackPanel Spacing="12" Padding="0,8">
                            <StackPanel>
                                <TextBlock x:Name="AboutName" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="AboutVersion" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock x:Name="AboutDesc" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock x:Name="SysOsText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                <TextBlock x:Name="SysCpuText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                <TextBlock x:Name="SysRamText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                <TextBlock x:Name="SysGpuText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                            </StackPanel>

                            <ItemsRepeater x:Name="MonitorsRepeater" ItemsSource="{x:Bind Monitors, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="6" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="helpers:MonitorDisplayInfo">
                                        <Border Padding="12,10"
                                                CornerRadius="6"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <StackPanel Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,1"
                                                            VerticalAlignment="Center"
                                                            Visibility="{x:Bind PrimaryBadgeVisibility}">
                                                        <TextBlock Text="P" FontSize="10" Foreground="White" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind ManufacturerModel}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                                <TextBlock Text="{x:Bind ResolutionLine}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                                <TextBlock Text="{x:Bind PositionLine}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <TextBox x:Name="SystemInfoBox"
                                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                     FontFamily="Consolas" FontSize="11" MaxHeight="300"
                                     BorderThickness="0" Background="Transparent"
                                     Visibility="Collapsed" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="CopySystemInfoBtn" Click="CopySystemInfo_Click">
                                    <TextBlock x:Uid="CopyDebugText" />
                                </Button>
                                <Button x:Name="ShowDebugBtn" Click="ShowDebugInfo_Click">
                                    <TextBlock x:Uid="ShowDebugText" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </tk:SettingsCard>
                </tk:SettingsExpander.Items>
            </tk:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
