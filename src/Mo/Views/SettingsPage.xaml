<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Mo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="2" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

            <!-- General -->
            <TextBlock x:Name="GeneralText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />

            <Grid Padding="16,12" CornerRadius="8,8,0,0"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="StartupLabel" />
                    <TextBlock x:Name="StartupDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" OnContent="" OffContent="" Margin="0,-4,0,-4" />
            </Grid>

            <Grid Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TrayLabel" />
                    <TextBlock x:Name="TrayDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.MinimizeToTrayOnClose, Mode=TwoWay}" OnContent="" OffContent="" Margin="0,-4,0,-4" />
            </Grid>

            <Grid Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="MinimizedLabel" />
                    <TextBlock x:Name="MinimizedDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" OnContent="" OffContent="" Margin="0,-4,0,-4" />
            </Grid>

            <Grid Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="ThemeLabel" />
                    <TextBlock x:Name="ThemeDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ComboBox Grid.Column="1" x:Name="ThemeCombo" MinWidth="120" VerticalAlignment="Center" SelectionChanged="ThemeCombo_SelectionChanged" />
            </Grid>

            <Grid Padding="16,12"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="AutoSwitchLabel" />
                    <TextBlock x:Name="AutoSwitchDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoSwitchEnabled, Mode=TwoWay}" OnContent="" OffContent="" Margin="0,-4,0,-4" />
            </Grid>

            <Grid Padding="16,12" CornerRadius="0,0,8,8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="UpdateLabel" />
                    <TextBlock x:Name="UpdateDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="UpdateStatusText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" Visibility="Collapsed" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CheckForUpdates, Mode=TwoWay}" OnContent="" OffContent="" Margin="0,-4,0,-4" />
                <Button Grid.Column="2" x:Name="CheckNowButton" Click="CheckNowButton_Click" VerticalAlignment="Center" />
            </Grid>

            <!-- Experimental -->
            <TextBlock x:Name="ExperimentalText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />

            <Grid Padding="16,12" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="RotationMethodLabel" />
                    <TextBlock x:Name="RotationMethodDesc" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                </StackPanel>
                <ComboBox Grid.Column="1" x:Name="RotationMethodCombo" MinWidth="140" MaxWidth="240" VerticalAlignment="Center" SelectionChanged="RotationMethodCombo_SelectionChanged" />
            </Grid>

            <!-- About -->
            <TextBlock x:Name="AboutText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />

            <Grid Padding="16" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="AboutName" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="AboutVersion" Opacity="0.6" />
                    <TextBlock x:Name="AboutDesc" Opacity="0.6" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <!-- System Info -->
            <TextBlock x:Name="SystemInfoTitle" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />

            <Grid Padding="16" CornerRadius="8,8,0,0"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="SysOsText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                    <TextBlock x:Name="SysCpuText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                    <TextBlock x:Name="SysRamText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                    <TextBlock x:Name="SysGpuText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                </StackPanel>
            </Grid>

            <!-- Monitors -->
            <TextBlock x:Name="MonitorSectionTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="16,12,0,4" />

            <StackPanel x:Name="MonitorCardsPanel" Spacing="2" />

            <!-- Debug Info -->
            <Grid Padding="16,12" CornerRadius="0,0,8,8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="DebugInfoDesc" Opacity="0.5" TextWrapping="Wrap"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox
                        x:Name="SystemInfoBox"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        FontFamily="Consolas"
                        FontSize="11"
                        MaxHeight="300"
                        BorderThickness="0"
                        Background="Transparent"
                        Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="CopySystemInfoBtn" Click="CopySystemInfo_Click" />
                        <Button x:Name="ShowDebugBtn" Click="ShowDebugInfo_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
