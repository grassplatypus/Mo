<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Mo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="4" MaxWidth="700" HorizontalAlignment="Left">

            <TextBlock x:Name="TitleText" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

            <!-- General -->
            <TextBlock x:Name="GeneralText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />

            <Grid Padding="16" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Launch at startup -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="StartupLabel" />
                        <TextBlock x:Name="StartupDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" />
                </Grid>

                <!-- Minimize to tray -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TrayLabel" />
                        <TextBlock x:Name="TrayDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.MinimizeToTrayOnClose, Mode=TwoWay}" />
                </Grid>

                <!-- Start minimized -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="MinimizedLabel" />
                        <TextBlock x:Name="MinimizedDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}" />
                </Grid>

                <!-- Theme -->
                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="ThemeLabel" />
                        <TextBlock x:Name="ThemeDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="ThemeCombo" Width="140" SelectionChanged="ThemeCombo_SelectionChanged" />
                </Grid>

                <!-- Auto-switch -->
                <Grid Grid.Row="4" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="AutoSwitchLabel" />
                        <TextBlock x:Name="AutoSwitchDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.AutoSwitchEnabled, Mode=TwoWay}" />
                </Grid>

                <!-- Check for updates -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="UpdateLabel" />
                        <TextBlock x:Name="UpdateDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock x:Name="UpdateStatusText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" Visibility="Collapsed" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.CheckForUpdates, Mode=TwoWay}" />
                    <Button Grid.Column="2" x:Name="CheckNowButton" Click="CheckNowButton_Click" Margin="8,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <!-- About -->
            <TextBlock x:Name="AboutText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,8" />

            <Grid Padding="16" CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="AboutName" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="AboutVersion" Opacity="0.6" />
                    <TextBlock x:Name="AboutDesc" Opacity="0.6" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
