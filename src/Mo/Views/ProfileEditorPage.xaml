<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Mo.Views.ProfileEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Mo.Controls"
    xmlns:local="using:Mo.Views"
    mc:Ignorable="d">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Padding="24,24,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Click="BackButton_Click" Margin="0,0,12,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>

            <TextBox
                Grid.Column="1"
                x:Name="ProfileNameBox"
                FontSize="20"
                FontWeight="SemiBold"
                BorderThickness="0"
                Background="Transparent" />
        </Grid>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,0">
            <StackPanel Spacing="16" MaxWidth="800">

                <!-- Description -->
                <TextBox
                    x:Name="DescriptionBox"
                    BorderThickness="0"
                    Background="Transparent"
                    Opacity="0.7" />

                <!-- Layout toolbar -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button x:Name="ImportCurrentBtn" Click="ImportCurrent_Click" ToolTipService.ToolTip="Import current system layout">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock x:Name="ImportCurrentLabel" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AlignHorizontalBtn" Click="AlignHorizontal_Click" ToolTipService.ToolTip="Align monitors horizontally, top-edge aligned">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A1;" FontSize="14" />
                            <TextBlock x:Name="AlignHorizontalLabel" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SetPrimaryBtn" Click="SetPrimary_Click" IsEnabled="False" ToolTipService.ToolTip="Make selected monitor primary">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE735;" FontSize="14" />
                            <TextBlock x:Name="SetPrimaryLabel" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Monitor Layout -->
                <controls:MonitorLayoutCanvas
                    x:Name="LayoutCanvas"
                    MinHeight="220"
                    IsEditable="True"
                    MonitorSelected="LayoutCanvas_MonitorSelected" />

                <!-- Connected monitors — always visible, badge shows whether each is
                     already in the profile. Removing in editor flips it back to addable. -->
                <Grid x:Name="AvailableMonitorsPanel" Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="AvailableMonitorsTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="AvailableMonitorsDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                        <ItemsRepeater x:Name="AvailableMonitorsList" ItemsSource="{x:Bind AvailableMonitors, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:AvailableMonitorItem">
                                    <Grid Padding="10,8" CornerRadius="6"
                                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Subtitle}" Opacity="0.6"
                                                       Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Center"
                                                Click="AddOrFocusMonitor_Click"
                                                Tag="{x:Bind}"
                                                Style="{StaticResource SubtleButtonStyle}">
                                            <Grid>
                                                <FontIcon Glyph="&#xE710;" FontSize="14"
                                                          Visibility="{x:Bind AddIconVisibility}" />
                                                <FontIcon Glyph="&#xE73E;" FontSize="14"
                                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                          Visibility="{x:Bind CheckIconVisibility}" />
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Grid>

                <!-- Selected Monitor Details -->
                <Grid
                    x:Name="MonitorDetailsPanel"
                    Padding="16"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Visibility="Collapsed">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ToggleSwitch
                        x:Name="MonitorEnabledToggle"
                        Toggled="MonitorEnabledToggle_Toggled"
                        Margin="0,0,0,8" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock x:Name="ResLabel" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                            <TextBlock x:Name="DetailResolution" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="RefreshLabel" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                            <TextBlock x:Name="DetailRefreshRate" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock x:Name="RotLabel" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" />
                            <ComboBox x:Name="RotationCombo" MinWidth="100" SelectionChanged="RotationCombo_SelectionChanged">
                                <ComboBoxItem Content="0°" Tag="0" />
                                <ComboBoxItem Content="90°" Tag="90" />
                                <ComboBoxItem Content="180°" Tag="180" />
                                <ComboBoxItem Content="270°" Tag="270" />
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="3" x:Name="RemoveMonitorBtn" Click="RemoveMonitor_Click"
                                VerticalAlignment="Center" ToolTipService.ToolTip="Remove monitor from profile">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        </Button>
                    </Grid>
                </Grid>

                <!-- Rotation Warning -->
                <InfoBar
                    x:Name="RotationWarningBar"
                    Severity="Warning"
                    IsOpen="False"
                    IsClosable="True" />

                <!-- Color Settings (shown when a monitor is selected) -->
                <Grid x:Name="ColorSettingsPanel" Padding="16" CornerRadius="8" Visibility="Collapsed"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="ColorTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="BrightnessLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="100" ValueChanged="ColorSlider_Changed" />
                            <TextBlock Grid.Column="2" x:Name="BrightnessValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ContrastLabel" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" x:Name="ContrastSlider" Minimum="0" Maximum="100" ValueChanged="ColorSlider_Changed" />
                            <TextBlock Grid.Column="2" x:Name="ContrastValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="R" VerticalAlignment="Center" Foreground="#FF4444" FontWeight="Bold" />
                            <Slider Grid.Column="1" x:Name="RedSlider" Minimum="0" Maximum="100" ValueChanged="ColorSlider_Changed" />
                            <TextBlock Grid.Column="2" x:Name="RedValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="G" VerticalAlignment="Center" Foreground="#44BB44" FontWeight="Bold" />
                            <Slider Grid.Column="1" x:Name="GreenSlider" Minimum="0" Maximum="100" ValueChanged="ColorSlider_Changed" />
                            <TextBlock Grid.Column="2" x:Name="GreenValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" /><ColumnDefinition Width="*" /><ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="B" VerticalAlignment="Center" Foreground="#4488FF" FontWeight="Bold" />
                            <Slider Grid.Column="1" x:Name="BlueSlider" Minimum="0" Maximum="100" ValueChanged="ColorSlider_Changed" />
                            <TextBlock Grid.Column="2" x:Name="BlueValue" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Extras Section -->
                <TextBlock x:Name="ExtrasTitle" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />

                <!-- Audio -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="AudioLabel" />
                        <TextBlock x:Name="AudioDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="AudioCombo" MinWidth="140" MaxWidth="280" SelectionChanged="AudioCombo_SelectionChanged" />
                </Grid>

                <!-- Wallpaper -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="WallpaperLabel" />
                        <TextBlock x:Name="WallpaperPathText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="WallpaperBrowseBtn" Click="WallpaperBrowse_Click" Margin="0,0,4,0" />
                    <Button Grid.Column="2" x:Name="WallpaperClearBtn" Click="WallpaperClear_Click" />
                </Grid>

                <!-- Night Light -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="NightLightLabel" />
                        <TextBlock x:Name="NightLightDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="NightLightCombo" MinWidth="120" MaxWidth="180" SelectionChanged="NightLightCombo_SelectionChanged" />
                </Grid>

                <!-- Live Wallpaper -->
                <Grid x:Name="LiveWallpaperCard" Padding="16" CornerRadius="8" Visibility="Collapsed"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="LiveWpLabel" />
                                <TextBlock x:Name="LiveWpProviderText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="LiveWpClearBtn" Click="LiveWpClear_Click" />
                        </Grid>
                        <ItemsControl x:Name="LiveWpEntries">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Opacity="0.5" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- Unmatched monitors -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="UnmatchedLabel" />
                        <TextBlock x:Name="UnmatchedDesc" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="UnmatchedCombo" MinWidth="120" MaxWidth="180" SelectionChanged="UnmatchedCombo_SelectionChanged" />
                </Grid>

                <!-- Auto-switch -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="AutoSwitchLabel" />
                        <TextBlock x:Name="AutoSwitchDescText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" x:Name="AutoSwitchToggle" Toggled="AutoSwitchToggle_Toggled" />
                </Grid>

                <!-- Schedule -->
                <Grid Padding="16" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="ScheduleLabel" />
                                <TextBlock x:Name="ScheduleDescText" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" x:Name="ScheduleToggle" Toggled="ScheduleToggle_Toggled" />
                        </Grid>

                        <StackPanel x:Name="ScheduleDetails" Visibility="Collapsed" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="ScheduleTimeLabel" VerticalAlignment="Center" />
                                <TimePicker x:Name="ScheduleTimePicker" ClockIdentifier="24HourClock" TimeChanged="ScheduleTime_Changed" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="ScheduleDaysLabel" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <ToggleButton x:Name="DayMon" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DayTue" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DayWed" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DayThu" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DayFri" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DaySat" MinWidth="40" Click="DayToggle_Click" />
                                    <ToggleButton x:Name="DaySun" MinWidth="40" Click="DayToggle_Click" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Bottom spacer -->
                <Border Height="16" />
            </StackPanel>
        </ScrollViewer>

        <!-- Action bar -->
        <Grid Grid.Row="2" Padding="24,12" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Click="CancelButton_Click" />
                <Button x:Name="SaveBtn" Style="{StaticResource AccentButtonStyle}" Click="SaveButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
