# Default: auto-detect
* text=auto

# Windows source files → CRLF
*.cs        text eol=crlf
*.xaml      text eol=crlf
*.csproj    text eol=crlf
*.props     text eol=crlf
*.targets   text eol=crlf
*.sln       text eol=crlf
*.slnx      text eol=crlf
*.resw      text eol=crlf
*.resx      text eol=crlf
*.manifest  text eol=crlf
*.pubxml    text eol=crlf
*.config    text eol=crlf

# Cross-platform text files → LF
*.md        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary — no conversion
*.ico       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.bmp       binary
*.pfx       binary
*.cer       binary
